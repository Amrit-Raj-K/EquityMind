{
    "installCommand": "npm install --prefix frontend",
    "buildCommand": "npm run build --prefix frontend",
    "outputDirectory": "frontend/dist/frontend/browser",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}