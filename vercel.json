{
    "installCommand": "npm install",
    "buildCommand": "npm run build --workspace=frontend --if-present",
    "outputDirectory": "frontend/dist/frontend/browser",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}